<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1E1E1E">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#444444"
        android:layout_marginBottom="16dp" />

    <!-- Detection Mode -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/detection_mode"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgDetectionMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbModeFrame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/frame_detection"
                android:textColor="#CCCCCC"
                android:checked="true"
                android:buttonTint="#00FFFF" />

            <RadioButton
                android:id="@+id/rbModeSliding"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sliding_window_mode"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FFFF" />

        </RadioGroup>

    </LinearLayout>

    <!-- Sliding Window Duration (only visible when sliding mode is selected) -->
    <LinearLayout
        android:id="@+id/layoutWindowDuration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sliding_window_duration"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgWindowDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbWindow3s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3s"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FFFF" />

            <RadioButton
                android:id="@+id/rbWindow5s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5s"
                android:textColor="#CCCCCC"
                android:checked="true"
                android:buttonTint="#00FFFF" />

            <RadioButton
                android:id="@+id/rbWindow10s"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10s"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FFFF" />

        </RadioGroup>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="8dp" />

    <!-- Frame Mode Pose Mapping -->
    <LinearLayout
        android:id="@+id/layoutFramePoseMapping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/frame_mode_mapping"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pose_to_state"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingBottom="8dp" />

        <!-- Head Up/Down -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/head_up_down"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerFrameHeadUpDown"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Head Left/Right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/head_left_right"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerFrameHeadLeftRight"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Posture Deviation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/posture_deviation"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerFramePostureDeviation"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Sliding Mode Pose Mapping (visible when sliding mode selected) -->
    <LinearLayout
        android:id="@+id/layoutSlidingPoseMapping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sliding_mode_mapping"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pose_to_state"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingBottom="8dp" />

        <!-- Head Up/Down -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/head_up_down"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerSlidingHeadUpDown"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Head Left/Right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/head_left_right"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerSlidingHeadLeftRight"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Posture Deviation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/posture_deviation"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerSlidingPostureDeviation"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="8dp" />

    <!-- Vibration Switch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/vibration"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchVibration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false" />

    </LinearLayout>

    <!-- Vibration Mode -->
    <LinearLayout
        android:id="@+id/layoutVibrationMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vibration_mode"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerVibrationMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#333333"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="8dp" />

    <!-- Audio Switch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/audio_alert"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAudio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />

    </LinearLayout>

    <!-- Audio Volume -->
    <LinearLayout
        android:id="@+id/layoutAudioVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/volume"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvVolumeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#00FFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/seekBarVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="100"
            android:paddingTop="8dp" />

    </LinearLayout>

    <!-- Tired Audio Selection -->
    <LinearLayout
        android:id="@+id/layoutTiredAudio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tired_audio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerTiredAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#333333"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Slightly Tired Audio Selection -->
    <LinearLayout
        android:id="@+id/layoutSlightlyTiredAudio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/slightly_tired_audio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerSlightlyTiredAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#333333"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="8dp" />

    <!-- Language Selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/language"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbLanguageAuto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto"
                android:textColor="#CCCCCC"
                android:checked="true"
                android:buttonTint="#00FFFF" />

            <RadioButton
                android:id="@+id/rbLanguageZh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/chinese"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FFFF" />

            <RadioButton
                android:id="@+id/rbLanguageEn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/english"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FFFF" />

        </RadioGroup>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="8dp" />

    <!-- Keypoint Settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/keypoint_settings"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <!-- Draw Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/draw_threshold"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvDrawThresholdValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.50"
                    android:textColor="#00FFFF"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/draw_threshold_desc"
                android:textColor="#888888"
                android:textSize="12sp"
                android:paddingTop="2dp" />

            <SeekBar
                android:id="@+id/seekBarDrawThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50"
                android:progress="20"
                android:paddingTop="8dp" />

        </LinearLayout>

        <!-- Analysis Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/analysis_threshold"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAnalysisThresholdValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.50"
                    android:textColor="#00FFFF"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/analysis_threshold_desc"
                android:textColor="#888888"
                android:textSize="12sp"
                android:paddingTop="2dp" />

            <SeekBar
                android:id="@+id/seekBarAnalysisThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50"
                android:progress="20"
                android:paddingTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#444444"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:backgroundTint="#555555"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/save" />

    </LinearLayout>

</LinearLayout>

</ScrollView>